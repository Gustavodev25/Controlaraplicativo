{
  "expo": {
    "name": "Controlar+",
    "slug": "controlarapp",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "controlarapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "newArchEnabled": true,
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "Controlar+",
        "NSFaceIDUsageDescription": "Usamos Face ID para proteger seu acesso ao app",
        "NSCameraUsageDescription": "Usamos a câmera para leitura de documentos e QR codes.",
        "NSPhotoLibraryUsageDescription": "Usamos a galeria para importar comprovantes e documentos.",
        "NSMicrophoneUsageDescription": "Acesso ao microfone necessário para algumas funcionalidades de mídia.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.gustavodev25.controlarapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "package": "com.gustavodev25.controlarapp",
      "versionCode": 8
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Usamos Face ID para proteger seu acesso ao app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splashscreen_logo.png",
          "backgroundColor": "#000000",
          "dark": {
            "image": "./assets/images/splashscreen_logo.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      ["react-native-iap", { "paymentProvider": "Apple" }],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5090aaec-94b6-440c-b5dd-c839eb3abb4d"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/5090aaec-94b6-440c-b5dd-c839eb3abb4d"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "autolinking": {
      "exclude": ["expo-glass-effect"],
      "ios": {
        "buildFromSource": [
          "react-native-reanimated",
          "react-native-worklets"
        ]
      }
    }
  }
}
