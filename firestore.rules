rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ========================================
    // AUTHENTICATE HELPER FUNCTIONS
    // ========================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Billing fields are controlled by verified store webhooks and backend routes.
    function billingFieldsUnchanged() {
      return request.resource.data.get('subscription', null) == resource.data.get('subscription', null)
        && request.resource.data.get('paymentMethod', null) == resource.data.get('paymentMethod', null)
        && request.resource.data.get('paymentMethodDetails', null) == resource.data.get('paymentMethodDetails', null)
        && request.resource.data.get('profile', {}).get('subscription', null) == resource.data.get('profile', {}).get('subscription', null)
        && request.resource.data.get('profile', {}).get('paymentMethod', null) == resource.data.get('profile', {}).get('paymentMethod', null)
        && request.resource.data.get('profile', {}).get('paymentMethodDetails', null) == resource.data.get('profile', {}).get('paymentMethodDetails', null)
        && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false)
        && request.resource.data.get('profile', {}).get('isAdmin', false) == resource.data.get('profile', {}).get('isAdmin', false);
    }

    function hasValidInitialBillingFields() {
      let subscription = request.resource.data.get('subscription', {});
      let profile = request.resource.data.get('profile', {});
      let profileSubscription = profile.get('subscription', {});
      return subscription.get('plan', 'starter') in ['starter', 'free']
        && subscription.get('status', 'active') in ['active', 'inactive']
        && profileSubscription.get('plan', 'starter') in ['starter', 'free']
        && profileSubscription.get('status', 'active') in ['active', 'inactive']
        && !request.resource.data.keys().hasAny(['paymentMethod', 'paymentMethodDetails'])
        && !profile.keys().hasAny(['paymentMethod', 'paymentMethodDetails'])
        && request.resource.data.get('isAdmin', false) == false
        && profile.get('isAdmin', false) == false;
    }
    
    // ========================================
    // ROOT COLLECTIONS
    // ========================================
    
    // Users collection - own profile
    match /users/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow create: if isAuthenticated() && isOwner(userId) && hasValidInitialBillingFields();
      allow update: if isAuthenticated() && isOwner(userId) && billingFieldsUnchanged();
      allow delete: if isAuthenticated() && isOwner(userId);
      
      // ========================================
      // USER SUBCOLLECTIONS
      // ========================================
      
      // Credit Card Transactions
      match /creditCardTransactions/{transactionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Bank Transactions
      match /transactions/{transactionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Accounts (Credit Cards, Bank Accounts, etc.)
      match /accounts/{accountId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Investments
      match /investments/{investmentId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
        
        // Investment Transactions/History
        match /{collectionId=**}/{document=**} {
          allow read: if isAuthenticated() && isOwner(userId);
          allow write: if isAuthenticated() && isOwner(userId);
        }
      }
      
      // Subscriptions
      match /subscriptions/{subscriptionId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Reminders
      match /reminders/{reminderId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Category Mappings
      match /categoryMappings/{categoryId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Analytics Monthly
      match /analytics_monthly/{monthKey} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Recurrence Blacklist
      match /recurrence_blacklist/{recurrenceId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Connected Accounts (Open Finance)
      match /connectedAccounts/{connectedId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated() && isOwner(userId);
        allow update: if isAuthenticated() && isOwner(userId);
        allow delete: if isAuthenticated() && isOwner(userId);
      }
      
      // Catch-all for any other user subcollections
      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if isAuthenticated() && isOwner(userId);
      }
    }
  }
}
