{
  "name": "controlarapp",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node scripts/patch-expo-cli.js",
    "start": "expo start --go",
    "start:dev-client": "expo start --dev-client",
    "dev": "concurrently -n server,expo -c blue,green --kill-others \"npm run server:dev\" \"expo start --go\"",
    "dev:android": "concurrently -n server,expo -c blue,green --kill-others \"npm run server:dev\" \"expo start --go --android\"",
    "dev:ios": "concurrently -n server,expo -c blue,green --kill-others \"npm run server:dev\" \"expo start --go --ios\"",
    "dev:web": "concurrently -n server,expo -c blue,green --kill-others \"npm run server:dev\" \"expo start --web\"",
    "dev:tunnel": "node scripts/dev-tunnel.js",
    "dev:tunnel:android": "node scripts/dev-tunnel.js --android",
    "dev:tunnel:ios": "node scripts/dev-tunnel.js --ios",
    "perf:collect": "powershell -ExecutionPolicy Bypass -File scripts/perf/collect-metrics.ps1",
    "perf:scenario": "powershell -ExecutionPolicy Bypass -File scripts/perf/run-scenario.ps1",
    "perf:parse-framestats": "npx tsx scripts/perf/parse-framestats.ts",
    "perf:summarize": "npx tsx scripts/perf/summarize.ts",
    "perf:check-assets": "npx tsx scripts/perf/check-asset-budgets.ts",
    "server": "cd server && node index.js",
    "server:dev": "cd server && npm run dev",
    "server:install": "cd server && npm install",
    "reset-project": "node ./scripts/reset-project.js",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:dev:ios-device": "eas build --profile development-device --platform ios",
    "build:dev:apk": "eas build --profile development-apk --platform android",
    "build:preview": "eas build --profile preview --platform android",
    "build:preview:ios": "eas build --profile preview-device --platform ios",
    "update:preview": "eas update --channel preview",
    "update:preview:ios": "eas update --channel preview --platform ios",
    "update:development": "eas update --channel development",
    "update:production": "eas update --channel production",
    "deploy:ios": "eas build --platform ios --profile production --auto-submit",
    "deploy:android": "eas build --platform android --profile production --auto-submit",
    "deploy:all": "eas build --platform all --profile production --auto-submit",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "tunnel:expo": "ssh -p 443 -R0:localhost:8081 qr@a.pinggy.io",
    "tunnel:server": "ssh -p 443 -R0:localhost:3001 qr@a.pinggy.io",
    "tunnel:cf": "cloudflared tunnel --url http://localhost:8081",
    "start:tunnel": "powershell -ExecutionPolicy Bypass -File scripts/start-with-tunnel.ps1"
  },
  "dependencies": {
    "@expo-google-fonts/ar-one-sans": "^0.4.2",
    "@expo/ui": "~56.0.17",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-masked-view/masked-view": "0.3.2",
    "expo": "~56.0.11",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.13",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-local-authentication": "~56.0.3",
    "expo-notifications": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.3",
    "expo-splash-screen": "~56.0.9",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.4",
    "firebase": "^12.7.0",
    "lucide-react-native": "^0.562.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-iap": "^15.2.0",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "victory-native": "^36.9.2"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "fast-check": "^4.5.3",
    "localtunnel": "^2.0.2",
    "qrcode-terminal": "^0.12.0",
    "ts-jest": "^29.4.6",
    "typescript": "~6.0.3"
  },
  "private": true
}
